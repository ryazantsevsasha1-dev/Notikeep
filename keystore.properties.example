# Copy this file to keystore.properties (which is gitignored) and fill in your
# real release keystore details. Generate a keystore once with:
#
#   keytool -genkey -v -keystore notikeep-release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias notikeep
#
# Then BACK UP the .jks file in two safe places — losing it means you can never
# update the app on RuStore again.

storeFile=../notikeep-release.jks
storePassword=CHANGE_ME
keyAlias=notikeep
keyPassword=CHANGE_ME
