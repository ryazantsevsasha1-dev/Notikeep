<?xml version="1.0" encoding="utf-8"?><!--
   API 31+ backup/transfer rules. The notification archive holds private message
   texts (incl. 2FA codes), so the database domain is excluded from both cloud
   backups and device-to-device transfer. Settings (datastore) may still back up.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="." />
    </device-transfer>
</data-extraction-rules>
