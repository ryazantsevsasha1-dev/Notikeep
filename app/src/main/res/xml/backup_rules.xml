<?xml version="1.0" encoding="utf-8"?><!--
   Auto Backup rules (API < 31 path; API 31+ uses data_extraction_rules.xml).
   The notification archive contains the full text of the user's notifications —
   private messages, 2FA codes, banking alerts. It must never leave the device,
   so the whole database domain (notikeep.db + WAL/journal files) is excluded.
-->
<full-backup-content>
    <exclude domain="database" path="." />
</full-backup-content>
