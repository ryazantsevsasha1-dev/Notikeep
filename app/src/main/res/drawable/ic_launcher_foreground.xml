<?xml version="1.0" encoding="utf-8"?>
<!--
    Notikeep launcher foreground: symmetric badge shield with a double white
    outline and a bold bell. Tuned for legibility at 48x48 px: no stroke is
    thinner than ~3 viewport units and the bell is one solid mass.
    Content stays inside the 66dp safe zone of the 108dp adaptive canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer white border of the shield -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,20 L80,27.5 L80,52
            C80,67.5 69,79.5 54,87.5
            C39,79.5 28,67.5 28,52
            L28,27.5 Z" />

    <!-- Shield body (brand indigo) -->
    <path
        android:fillColor="#4C5FD5"
        android:pathData="M54,23.6 L76.6,30.2 L76.6,51.8
            C76.6,65.6 66.9,76.3 54,83.5
            C41.1,76.3 31.4,65.6 31.4,51.8
            L31.4,30.2 Z" />

    <!-- Inner white ring -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,27.4 L73.2,33 L73.2,51.5
            C73.2,63.4 64.8,72.8 54,79.2
            C43.2,72.8 34.8,63.4 34.8,51.5
            L34.8,33 Z" />

    <!-- Shield core (deeper premium blue for contrast under the bell) -->
    <path
        android:fillColor="#2E44BE"
        android:pathData="M54,30.6 L70.2,35.4 L70.2,51.3
            C70.2,61.5 63.1,69.6 54,75.4
            C44.9,69.6 37.8,61.5 37.8,51.3
            L37.8,35.4 Z" />

    <!-- Bell: knob + body as one bold white mass -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,36.4 m-3.4,0 a3.4,3.4 0 1,1 6.8,0 a3.4,3.4 0 1,1 -6.8,0" />
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,39.6
            C47.2,39.6 41.8,45 41.8,51.8
            L41.8,58.2
            L39.2,62.4
            C38.5,63.6 39.4,65 40.8,65
            L67.2,65
            C68.6,65 69.5,63.6 68.8,62.4
            L66.2,58.2
            L66.2,51.8
            C66.2,45 60.8,39.6 54,39.6 Z" />
    <!-- Clapper -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M49.4,67.4 a4.6,4.6 0 0,0 9.2,0 Z" />
</vector>
